MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=xiyiyun
MYSQL_USER=xiyiyun
MYSQL_PASSWORD=change_me_user
XIYIYUN_ADMIN_USERNAME=admin
# htpasswd -nbBC 12 '' 'your_admin_password' | sed 's/^://'
XIYIYUN_ADMIN_PASSWORD_BCRYPT=please_generate_bcrypt_hash
XIYIYUN_ADMIN_NICKNAME=运营管理员
# Replace before exposing payment callbacks. Generate with:
# openssl rand -hex 32
XIYIYUN_PAYMENT_CALLBACK_SECRET=change_me_payment_callback_secret
# Replace before importing production cards. Generate with:
# openssl rand -hex 32
XIYIYUN_CARD_ENCRYPTION_SECRET=change_me_card_encryption_secret
# Comma-separated browser origins allowed to call the backend directly.
# Replace with the exact production Web, H5, and Admin origins. Do not use "*".
XIYIYUN_CORS_ALLOWED_ORIGINS=https://shop.your-domain.com,https://h5.your-domain.com,https://admin.your-domain.com
# Bind container HTTP ports to localhost. Expose production traffic through an HTTPS reverse proxy.
XIYIYUN_HTTP_BIND=127.0.0.1
WEB_PORT=80
H5_PORT=18080
ADMIN_PORT=8088
# Optional build mirrors. Keep defaults for China-friendly server builds,
# or set to official sources if your server reaches them reliably.
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
