MYSQL_ROOT_PASSWORD=please_change_root_password
MYSQL_DATABASE=xiyiyun
MYSQL_USER=xiyiyun
MYSQL_PASSWORD=please_change_user_password
XIYIYUN_ADMIN_USERNAME=admin
# Generate with: htpasswd -nbBC 12 '' 'your_admin_password' | sed 's/^://'
XIYIYUN_ADMIN_PASSWORD_BCRYPT=please_generate_bcrypt_hash
XIYIYUN_ADMIN_NICKNAME=运营管理员
# Generate with: openssl rand -hex 32
XIYIYUN_PAYMENT_CALLBACK_SECRET=please_generate_payment_callback_secret
# Generate with: openssl rand -hex 32
XIYIYUN_CARD_ENCRYPTION_SECRET=please_generate_card_encryption_secret
# Comma-separated browser origins allowed to call the backend directly.
# Replace with the exact HTTPS Feiniu/LAN or public origins used by Web, H5, and Admin. Do not use "*".
XIYIYUN_CORS_ALLOWED_ORIGINS=https://web.example.com,https://h5.example.com,https://admin.example.com
# Bind container HTTP ports to localhost. Use an HTTPS reverse proxy for real external access.
XIYIYUN_HTTP_BIND=127.0.0.1
WEB_PORT=18080
H5_PORT=18081
ADMIN_PORT=18088
# Optional build mirrors. Keep defaults for China-friendly server builds,
# or set to official sources if your server reaches them reliably.
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
